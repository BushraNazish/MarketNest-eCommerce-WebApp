# Postgres Database Credentials
DB_PASSWORD=your_secure_db_password_here

# JWT Secret (Must be a secure 256-bit or large pseudo-random string)
# You can generate one using: openssl rand -base64 64
JWT_SECRET=your_secure_jwt_secret_generator_here

# Razorpay Configuration (Optional for Local Dev, Required for Production)
RAZORPAY_KEY_ID=mock_key_id
RAZORPAY_KEY_SECRET=mock_key_secret

# Other Integrations
REDIS_PASSWORD=
SENDGRID_API_KEY=dummy
MSG91_AUTH_KEY=dummy
CLOUDINARY_CLOUD_NAME=dummy
CLOUDINARY_API_KEY=dummy
CLOUDINARY_API_SECRET=dummy
